rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // WARNING: This allows anyone to read and write to your database.
      // For a personal portfolio, this is okay for now, but in production 
      // you should restrict write access to your authenticated admin user.
      allow read, write: if true;
    }
  }
}
